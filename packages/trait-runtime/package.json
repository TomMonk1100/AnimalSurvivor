{
  "name": "@animalsurvivor/trait-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Renderer-independent deterministic trait/evolution/Mythic runtime for AnimalSurvivor. Zero runtime dependencies.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test \"dist/test/*.test.js\"",
    "lint": "node scripts/lint.mjs",
    "bench": "tsc -p tsconfig.json && node dist/bench/bench.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
