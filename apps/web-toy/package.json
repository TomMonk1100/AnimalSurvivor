{
  "name": "web-toy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Gate 1 browser technical toy: renders the accepted headless deterministic simulation via PlayCanvas without letting rendering affect gameplay state.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "verify:content": "vitest run test/content-validator.test.ts",
    "verify:assets": "node scripts/verify-assets.mjs",
    "verify:artifact": "node scripts/verify-dist.mjs",
    "verify:served": "node scripts/verify-served-artifact.mjs",
    "verify:agent-smoke": "node scripts/verify-agent-smoke.mjs",
    "golden:propose": "node scripts/propose-golden-hashes.mjs",
    "vfx:capture": "node scripts/vfx-capture.mjs",
    "vfx:make-signature-v3": "node scripts/make-signature-v3.mjs",
    "vfx:flash-audit": "node scripts/flash-audit.mjs",
    "vfx:make-p3-crops": "node scripts/make-p3-crops.mjs",
    "vfx:reencode-textures": "node scripts/reencode-vfx-textures.mjs --write",
    "assets:reencode-runtime-pngs": "node scripts/reencode-vfx-textures.mjs --include-ui-runtime --write",
    "verify:vfx-textures": "node scripts/verify-vfx-textures.mjs",
    "verify:vfx-flash": "node scripts/vfx-capture.mjs --flash-only --preview --headless",
    "test:watch": "vitest",
    "serve": "vite --host",
    "stress": "vite --host --open \"/?autopilot=1&stress=1&renderstress=1\""
  },
  "dependencies": {
    "playcanvas": "^2.20.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
