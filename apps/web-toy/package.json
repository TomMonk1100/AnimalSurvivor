{
  "name": "web-toy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Gate 1 browser technical toy: renders the accepted headless deterministic simulation via PlayCanvas without letting rendering affect gameplay state.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "vite --host",
    "stress": "vite --host --open \"/?autopilot=1&stress=1&renderstress=1\""
  },
  "dependencies": {
    "playcanvas": "^2.20.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
